.nav-bar {
  width: 100%;
  position: sticky;
  top: 0;
  z-index: 999;
}
.nav-content {
  height: 88rpx;            /* 导航栏高度，可自行调整 */
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 40rpx;         /* 这里就是大号字，您可以改成 44rpx 或更大 */
  font-weight: bold;
  color: #fff;
}