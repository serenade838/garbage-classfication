.page {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 40rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 30rpx;
}

.filter-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  padding: 0 20rpx;
}

.filter-btn {
  background: #4CAF50;
  color: #fff;
  border-radius: 30rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 28rpx;
}

.refresh-btn {
  background: #2196F3;
  color: #fff;
  border-radius: 30rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 28rpx;
  margin-left: 10rpx;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.info {
  flex: 1;
  margin-left: 20rpx;
}

.category {
  font-size: 32rpx;
  font-weight: 500;
  color: #222;
}

.confidence {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.delete-btn {
  background: #ff4d4f;
  color: #fff;
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty {
  text-align: center;
  margin-top: 100rpx;
  color: #aaa;
  font-size: 28rpx;
}

/* 分页 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 30rpx;
}

.page-btn {
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  color: #333;
}

.page-btn[disabled] {
  color: #ccc;
}

.page-info {
  margin: 0 30rpx;
  font-size: 26rpx;
  color: #666;
}