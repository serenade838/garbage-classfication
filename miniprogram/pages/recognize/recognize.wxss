/* pages/recognize/recognize.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.preview {
  width: 100%;
  height: 400rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.preview image {
  width: 100%;
  height: 100%;
}
.placeholder {
  color: #aaa;
  font-size: 28rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.actions button {
  flex: 1;
  background: #fff;
  color: #333;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}

.btn-recognize {
  width: 100%;
  background: #4CAF50;
  color: #fff;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.btn-recognize[disabled] {
  background: #ccc;
  color: #888;
}

.result {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 16rpx;
}

.result-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.result-item:last-child {
  border-bottom: none;
}
.category {
  font-size: 30rpx;
  font-weight: 500;
  color: #222;
}
.confidence {
  font-size: 28rpx;
  color: #666;
  margin-top: 6rpx;
}
.advice {
  font-size: 28rpx;
  color: #4CAF50;
  margin-top: 6rpx;
}
.tips {
  font-size: 26rpx;
  color: #999;
  margin-top: 4rpx;
}

.btn-feedback {
  margin-top: 20rpx;
  background: #FF9800;
  color: #fff;
  border-radius: 40rpx;
}

.preview-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.preview-image {
  width: 100%;
  height: 100%;
}
.preview-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}