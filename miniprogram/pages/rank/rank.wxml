<!-- 自定义导航栏 -->
<nav-bar title="排行榜"></nav-bar>

<view class="page">
  <!-- 顶部周期选择器（美化） -->
  <view class="picker-wrapper">
    <picker mode="selector" range="{{cycles}}" value="{{cycleIndex}}" bindchange="onCycleChange">
      <view class="picker-display">
        <text class="picker-label">周期：</text>
        <text class="picker-value">{{cycles[cycleIndex]}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 排名列表 -->
  <view class="rank-list">
    <view wx:for="{{rankList}}" wx:key="rank" class="rank-item {{item.rank <= 3 ? 'top' + item.rank : ''}}">
      <view class="rank-number">
        <text wx:if="{{item.rank === 1}}">🥇</text>
        <text wx:elif="{{item.rank === 2}}">🥈</text>
        <text wx:elif="{{item.rank === 3}}">🥉</text>
        <text wx:else class="rank-num">{{item.rank}}</text>
      </view>
      <view class="rank-info">
        <view class="nickname">{{item.nickname}}</view>
        <view class="count">{{item.total_recognition}} 次识别</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{rankList.length === 0}}" class="empty">暂无排行数据</view>
</view>