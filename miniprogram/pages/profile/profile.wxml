<!-- 自定义导航栏 -->
<nav-bar title="我的"></nav-bar>

<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">{{userInfo.nickname ? userInfo.nickname[0] : '?'}}</view>
    <view class="user-info">
      <view class="nickname-row">
        <text class="nickname">{{userInfo.nickname || '未设置'}}</text>
        <text class="edit-tag" bindtap="editNickname">修改</text>
      </view>
      <text class="phone">{{userInfo.phone || ''}}</text>
    </view>
  </view>

  <!-- 统计数据卡片（只显示识别次数，楼栋移至下方可编辑） -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-number">{{userInfo.total_recognition || 0}}</text>
      <text class="stat-label">识别次数</text>
    </view>
  </view>

  <!-- 信息列表：楼栋可修改，注册时间只读 -->
  <view class="info-list">
    <!-- 楼栋（可修改） -->
    <view class="list-item">
      <text class="label">楼栋</text>
      <text class="value">{{userInfo.building || '未设置'}}</text>
      <text class="edit-tag" bindtap="editBuilding">修改</text>
    </view>
    <!-- 注册时间（只读） -->
    <view class="list-item">
      <text class="label">注册时间</text>
      <text class="value">{{userInfo.created_at || '--'}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-group">
      <!-- 在 action-group 中添加 -->
    <button class="action-btn primary" bindtap="goFeedbackList">我的反馈</button>
    <button class="action-btn primary" bindtap="goChangePassword">修改密码</button>
    <button class="action-btn danger" bindtap="logout">退出登录</button>
  </view>
</view>