.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}
.search-btn {
  background: #4CAF50;
  color: #fff;
  border-radius: 30rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 28rpx;
}

.rule-list {
  margin-top: 20rpx;
}
.rule-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.rule-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #222;
}
.rule-category {
  font-size: 28rpx;
  color: #4CAF50;
  margin-top: 6rpx;
}
.rule-advice {
  font-size: 26rpx;
  color: #666;
  margin-top: 4rpx;
}

.empty {
  text-align: center;
  margin-top: 80rpx;
  color: #aaa;
  font-size: 28rpx;
}