<nav-bar title="修改密码"></nav-bar>

<view class="container">
  <view class="form">
    <view class="form-item">
      <text class="label">旧密码</text>
      <input class="input" type="password" placeholder="请输入旧密码" bindinput="onOldPwdInput" value="{{oldPassword}}" />
    </view>
    <view class="form-item">
      <text class="label">新密码</text>
      <input class="input" type="password" placeholder="请输入新密码（不少于6位）" bindinput="onNewPwdInput" value="{{newPassword}}" />
    </view>
    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="input" type="password" placeholder="请再次输入新密码" bindinput="onConfirmPwdInput" value="{{confirmPassword}}" />
    </view>
    <button class="submit-btn" bindtap="submit">确认修改</button>
  </view>
</view>