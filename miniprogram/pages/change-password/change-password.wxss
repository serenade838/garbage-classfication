.container {
  padding: 40rpx 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border-bottom: 2rpx solid #e0e0e0;
  font-size: 30rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.submit-btn {
  display: block;
  margin: 20rpx auto 0;
  background: #4CAF50;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border: none;
  width: auto;
  min-width: 200rpx;
}